# Supabase — get values from https://supabase.com/dashboard > Project > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Magic-link redirect target (optional, defaults to localhost)
APP_URL=http://localhost:8000

# Comma-separated list of origins allowed to call the API.
# Leave unset to use the built-in defaults (sports-hub-sepia.vercel.app + localhost).
# CORS_ALLOWED_ORIGINS=https://sports-hub-sepia.vercel.app,http://localhost:3000

# HockeyTech feed keys (public keys used by WHL/OHL/QMJHL websites).
# Override here if HockeyTech rotates them; otherwise the app falls back
# to the current published values.
# HOCKEYTECH_KEY_WHL=
# HOCKEYTECH_KEY_OHL=
# HOCKEYTECH_KEY_QMJHL=
